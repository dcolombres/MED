// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  dni           String?
  phone         String?
  triages       Triage[]
  consultations Consultation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model MagicLinkToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

model Triage {
  id                  String         @id @default(cuid())
  symptoms            String         // SQLite simplified: we can store as JSON string or use Json type
  motivo              String?
  identityNumber      String?
  requiresCertificate Boolean        @default(false)
  additionalData      String?        // JSON string
  status              TriageStatus   @default(PENDING)
  userId              String?
  user                User?          @relation(fields: [userId], references: [id])
  consultation        Consultation?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

enum TriageStatus {
  PENDING
  COMPLETED
  PAID
  EXPIRED
}

model Doctor {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  matricula     String         @unique
  especialidad  String         @default("Clínica Médica")
  status        DoctorStatus   @default(AVAILABLE)
  consultations Consultation[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum DoctorStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

model Consultation {
  id                 String              @id @default(cuid())
  triageId           String              @unique
  triage             Triage              @relation(fields: [triageId], references: [id])
  userId             String?
  user               User?               @relation(fields: [userId], references: [id])
  doctorId           String?
  doctor             Doctor?             @relation(fields: [doctorId], references: [id])
  status             ConsultationStatus  @default(WAITING)
  messages           Message[]
  payment            Payment?
  prescription       Prescription?
  medicalCertificate MedicalCertificate?
  startedAt          DateTime?
  endedAt            DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

enum ConsultationStatus {
  WAITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Message {
  id             String       @id @default(cuid())
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id])
  senderType     String       // "PATIENT" or "DOCTOR"
  senderId       String
  content        String
  imageUrl       String?
  createdAt      DateTime     @default(now())

  @@index([consultationId])
}

model Payment {
  id             String       @id @default(cuid())
  consultationId String       @unique
  consultation   Consultation @relation(fields: [consultationId], references: [id])
  mpPreferenceId String?
  mpPaymentId    String?
  status         String       @default("PENDING")
  amount         Float
  currency       String       @default("ARS")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Prescription {
  id               String       @id @default(cuid())
  consultationId   String       @unique
  consultation     Consultation @relation(fields: [consultationId], references: [id])
  medications      String       // JSON string for medications list
  observations     String?
  pdfUrl           String?
  verificationCode String       @unique
  issuedAt         DateTime     @default(now())
}

model MedicalCertificate {
  id               String       @id @default(cuid())
  consultationId   String       @unique
  consultation     Consultation @relation(fields: [consultationId], references: [id])
  daysOff          Int
  diagnosis        String?
  returnDate       DateTime
  pdfUrl           String?
  verificationCode String       @unique
  issuedAt         DateTime     @default(now())
}
